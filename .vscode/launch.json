{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python Debugger: Django",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/food-waste-rescue/manage.py",
            "windows": {
                "python": "${workspaceFolder}/food-waste-rescue/.env/Scripts/python.exe",
            },
            "linux": {
                "python": "${workspaceFolder}/food-waste-rescue/.env/bin/python"
            },
            "cwd": "${workspaceFolder}/food-waste-rescue",
            "args": [
                "runserver"
            ],
            "django": true
        }
    ]
}