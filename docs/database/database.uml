@startuml
entity Seller {
  +seller_id: INT <PK>
  +name: STR
  +location: STR
  +opening_time: Time
  +closing_time: Time
  +telephone_number: STR
  +email: STR
  +websiteURL: STR
}

entity Bundle_posting{
    +posting_id: INT <PK>
    +seller_id: INT <FK>
    +category: STR
    +contents_description: STR
    +allergens: INT
    +quantity: INT
    +price: Float
    +creation_time: epoch
    +pickup_window_start: Time
    +pickup_window_end: Time
}

entity Reservation{
    +reservation_id: INT <PK>
    +posting_id: INT <FK>
    +consumer_id: INT <FK>
    +timestamp: epoch
    +claim_code: INT
    +status: STR
}
entity Consumer{
        +consumer_id: INT <PK>
        +display_name: STR
        +email: STR
}
entity IssueReport{
    +issue_id: INT <PK>
    +posting_id: INT <FK>
    +consumer_id: INT <FK>
    +type: STR
    +description: STR
    +status: STR
    +seller_response: STR
    +creation_time: epoch
}

entity ForecastOutput{
    +output_id: INT <PK>
    +posting_id: INT <FK>
    +predicted_reservation: INT
    +predicted_no_show_prob: INT 
    +confidence: INT
    +rationale: STR
    +time_recommendation: Time
    +type: STR
}

Reservation "0..*" }-- "1" Consumer : Creates <
IssueReport "0..*" }-- "1" Consumer : Submits <
IssueReport "0..*" }-- "1" Bundle_posting : Responds to >
Reservation "0..*" }-- "1" Bundle_posting : Is For >
Bundle_posting "0..*" }-- "1" Seller : Creates <
ForecastOutput "1" -- "1" Bundle_posting : Is Created For >


@enduml